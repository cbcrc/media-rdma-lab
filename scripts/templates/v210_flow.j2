    },
    {
      "name": "Cb",
      "width": {{ (frame_width | default(1920) // 2) }},
      "height": {{ frame_height }},
      "bit_depth": 10
    },
    {
      "name": "Cr",
      "width": {{ (frame_width | default(1920) // 2) }},
      "height": {{ frame_height }},
      "bit_depth": 10
    }
  ]
