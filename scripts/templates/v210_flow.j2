    "urn:x-nmos:tag:grouphint/v1.0": [
      "Media Function XYZ:Video"
    ]
  },
  "format": "urn:x-nmos:format:video",
  "label": "{{ flow_label | default('v210 1080p29') }}",
  "parents": [],
  "media_type": "video/v210",
  "grain_rate": {
    "numerator": {{ frame_rate_numerator | default(30000) }},
    "denominator": {{ frame_rate_denominator | default(1001)  }}
  },
  "frame_width": {{ frame_width | default(1920) }},
  "frame_height": {{ frame_height | default(1080) }},
  "interlace_mode": "progressive",
  "colorspace": "BT709",
  "components": [
    {
      "name": "Y",
      "width": {{ frame_width | default(1920) }},
      "height": {{ frame_height | default(1080) }},
